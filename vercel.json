{
  "rewrites": [
    { "source": "/pptxgen.bundle.js", "destination": "https://cdn.jsdelivr.net/npm/pptxgenjs@3.12.0/dist/pptxgen.bundle.js" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "functions": {
    "api/llm.js": { "maxDuration": 60 },
    "api/search.js": { "maxDuration": 30 }
  }
}
